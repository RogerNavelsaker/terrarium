{
	"name": "terrarium",
	"version": "0.1.0",
	"description": "CLI tool for seeds graph analysis, designed for agents and tools.",
	"author": "Jaymin West",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/RogerNavelsaker/terrarium.git"
	},
	"homepage": "https://github.com/RogerNavelsaker/terrarium#readme",
	"bugs": {
		"url": "https://github.com/RogerNavelsaker/terrarium/issues"
	},
	"keywords": [
		"os-eco",
		"terrarium",
		"seeds",
		"cli",
		"graph"
	],
	"bin": {
		"terrarium": "./src/index.ts",
		"tr": "./src/index.ts"
	},
	"main": "src/index.ts",
	"files": [
		"src",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"scripts": {
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"version:bump": "bun run scripts/version-bump.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"typescript": "^5.9.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"commander": "^15.0.0"
	}
}
