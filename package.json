{
	"name": "@os-eco/terrarium-cli",
	"version": "0.1.0",
	"description": "CLI tool for graph analysis, designed for agents and tools.",
	"type": "module",
	"bin": {
		"tr": "./src/index.ts",
		"terrarium": "./src/index.ts"
	},
	"main": "src/index.ts",
	"files": ["src"],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"keywords": ["os-eco", "terrarium", "seeds", "cli", "graph"],
	"author": "Roger Navelsaker",
	"license": "MIT",
	"homepage": "https://github.com/RogerNavelsaker/terrarium#readme",
	"bugs": {
		"url": "https://github.com/RogerNavelsaker/terrarium/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/RogerNavelsaker/terrarium.git"
	},
	"scripts": {
		"test": "bun test",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write --error-on-warnings .",
		"typecheck": "tsc --noEmit",
		"check:size": "bun run scripts/check-file-sizes.ts --budget scripts/file-size-budgets.json",
		"check:debt": "bun run scripts/check-debt-markers.ts --budget scripts/debt-markers-budget.json",
		"check:dups": "bunx jscpd",
		"check:deps": "knip --dependencies",
		"check:coverage": "bun run scripts/check-coverage.ts --budget scripts/coverage-budgets.json || true",
		"check:agents": "bun run scripts/validate-agents-md.ts --known-missing docs/check-all-standard.md || true",
		"check:ci-parity": "bun scripts/check-ci-parity.ts || true",
		"check:all": "bun scripts/check-all.ts",
		"verify": "bun run check:all",
		"test:ci": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage --reporter=junit --reporter-outfile=junit.xml || true",
		"report:test-timing": "bun run scripts/report-test-timing.ts || true",
		"report:quality": "bun run scripts/report-quality-metrics.ts || true",
		"version:bump": "bun run scripts/version-bump.ts",
		"prepare": "[ -e .git ] && git config core.hooksPath scripts/hooks || true"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "latest",
		"knip": "^6",
		"typescript": "^5.9.0",
		"yaml": "^2.9.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"commander": "^15.0.0"
	}
}
